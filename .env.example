# Copy this file to `.env` and fill in only the fields you need.

# LLM provider and model override
# Supported providers:
# - openai
# - openai_compatible
# - anthropic
# - ollama
AI_INTAKE_LLM_PROVIDER=
AI_INTAKE_LLM_MODEL=

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_TEMPERATURE=0.3
OPENAI_MODEL_TOKENS=500

# Anthropic
ANTHROPIC_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral-nemo:latest
OLLAMA_API_KEY=
OLLAMA_TEMPERATURE=0.7
OLLAMA_MODEL_TOKENS=128000

# Feishu personal bot
FEISHU_WEBHOOK_URL=
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Optional existing channels
WECOM_WEBHOOK_URL=
SERVERCHAN_SENDKEY=
PUSHPLUS_TOKEN=
